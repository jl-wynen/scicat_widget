{
    "scripts": {
        "dev": "npm run build -- --sourcemap=inline --watch",
        "build": "esbuild js/*.ts --minify --format=esm --bundle --outdir=src/scicat_widget/_static --loader:.svg=text",
        "fixture:serve": "esbuild tests/components/fixture/mount.ts --bundle --outfile=tests/components/fixture/mount.js --format=esm --loader:.svg=text --servedir=tests/components/fixture",
        "fix:prettier": "npm run lint:prettier -- --write",
        "lint:prettier": "prettier --config package.json --check",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {},
    "devDependencies": {
        "@anywidget/types": "^0.2.0",
        "@jupyterlab/galata": "^5.5.4",
        "@playwright/test": "^1.58.2",
        "@types/node": "^25.2.3",
        "esbuild": "^0.25.4",
        "prettier": "^3.7.4",
        "typescript": "^5.8.3"
    },
    "prettier": {
        "printWidth": 88,
        "tabWidth": 4
    }
}
